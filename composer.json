{
    "name": "rudashi/optima",
    "description": "Unofficial wrapper for ERP Comarch OPTIMA.",
    "keywords": [
        "laravel",
        "comarch",
        "optima",
        "api"
    ],
    "homepage": "https://github.com/rudashi/optima",
    "authors": [
        {
            "name": "Borys Żmuda",
            "email": "rudashi@gmail.com",
            "homepage": "https://rudashi.github.io",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2 || ^8.3",
        "laravel/framework": "^12.0|^13.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^10.11",
        "pestphp/pest": "^v4.0",
        "roave/security-advisories": "dev-latest"
    },
    "autoload": {
        "psr-4": {
            "Rudashi\\Optima\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Rudashi\\Optima\\Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Rudashi\\Optima\\OptimaServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "test": ["@test:bundles", "@test:integration"],
        "test:arch": "vendor/bin/pest --configuration=phpunit.xml --testsuite=arch",
        "test:bundles": "vendor/bin/pest --configuration=phpunit.xml --testsuite=bundles",
        "test:integration": "vendor/bin/pest --configuration=phpunit.xml --testsuite=integration",
        "test:mutate": "vendor/bin/pest --mutate",
        "pint": "vendor/bin/pint",
        "analyse": "vendor/bin/phpstan analyse",
        "coverage": "vendor/bin/pest --coverage",
        "profile": "vendor/bin/pest --profile",
        "styles": "vendor/bin/pint --test"
    }
}
