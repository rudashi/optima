# Test / smoke database connection
# Local Docker: MS_HOST=mssql (matches docker-compose.yml service name)
# Staging/prod smoke: injected via GitHub Environment secrets, do NOT fill in here
MS_HOST=
MS_PORT=1433
MS_DATABASE=

# Read connection
MS_USERNAME=
MS_PASSWORD=

# Write connection (optional — falls back to MS_USERNAME / MS_PASSWORD)
MS_SUDO_USERNAME=
MS_SUDO_PASSWORD=
